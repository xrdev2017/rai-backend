# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret
JWT_SECRET_ADMIN=your_admin_jwt_secret
JWT_EXPIRES_IN=7d
COOKIE_SECRET=your_cookie_secret

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_UN_AUTH=false

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=your_bucket_name

# ── Apple App Store Server API (In-App Purchases / Subscriptions) ─────────────
# Found in App Store Connect → Users and Access → Keys → In-App Purchase
APPLE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APPLE_KEY_ID=XXXXXXXXXX
# Paste the entire contents of your .p8 key file, replacing newlines with \n
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----"
# Your app's bundle identifier (e.g. com.example.myapp)
APPLE_BUNDLE_ID=com.example.myapp

# ── Google Play Developer API (In-App Purchases / Subscriptions) ──────────────
# Create a Service Account in Google Cloud Console, grant it permissions in
# Google Play Console, then download the JSON key and paste its contents here.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
